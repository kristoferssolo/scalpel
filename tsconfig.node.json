{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "jsx": "react-jsx",
    "strict": true,
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": [
    "src/main/**/*",
    "src/preload/**/*",
    "src/shared/**/*",
    "src/plugin-sdk/**/*",
    "src/renderer/src/env.d.ts",
    "electron.vite.config.ts"
  ],
  "exclude": ["src/plugin-sdk/dist/**", "src/plugin-sdk/node_modules/**", "src/shared/data/filter/filter-actions.ts"]
}
