{
  "name": "scalpel",
  "version": "0.9.8-rc8",
  "description": "Path of Exile's First Fourth-Party Tool",
  "author": "Scalpel",
  "license": "AGPL-3.0-only",
  "homepage": "https://github.com/scalpelpoe/scalpel",
  "repository": {
    "type": "git",
    "url": "https://github.com/scalpelpoe/scalpel.git"
  },
  "main": "out/main/index.js",
  "scripts": {
    "dev": "npm run build:internal-assets && node scripts/sync-regex-data.js & electron-vite dev",
    "build": "npm run build:internal-assets && electron-vite build",
    "build:internal-assets": "node scripts/build-internal-assets.mjs",
    "sync-regex": "node scripts/sync-regex-data.js",
    "sync-prefabs": "node scripts/sync-prefabs.js",
    "dist:win": "npm run build && electron-builder --win --x64",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "postinstall": "electron-rebuild",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepare": "husky"
  },
  "dependencies": {
    "active-win": "^9.0.0",
    "electron-overlay-window": "^4.0.2",
    "electron-store": "^8.2.0",
    "konva": "^9.3.22",
    "react-konva": "^18.2.14",
    "react-sortablejs": "^6.1.4",
    "sortablejs": "^1.15.7",
    "uiohook-napi": "^1.5.4",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@electron/asar": "^4.1.1",
    "@icon-park/react": "^1.4.2",
    "@storybook/react-vite": "^10.3.6",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sortablejs": "^1.15.9",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.27",
    "cheerio": "^1.2.0",
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.3.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.9",
    "prettier": "^3.8.1",
    "rcedit": "^5.0.2",
    "react": "^18.3.1",
    "react-colorful": "^5.6.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.5",
    "storybook": "^10.3.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.6.3",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,json,md}": [
      "prettier --write"
    ]
  },
  "build": {
    "appId": "com.filterscalpel.app",
    "productName": "Scalpel",
    "directories": {
      "output": "dist"
    },
    "afterPack": "./scripts/afterPack.js",
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico",
      "signAndEditExecutable": true
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "allowElevation": true,
      "createDesktopShortcut": false,
      "artifactName": "Scalpel-Setup.${ext}"
    },
    "extraResources": [
      {
        "from": "resources/icon.ico",
        "to": "icon.ico"
      }
    ],
    "asar": true,
    "asarUnpack": [
      "node_modules/uiohook-napi/**/*",
      "node_modules/electron-overlay-window/**/*"
    ],
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "!node_modules/.cache",
      "!node_modules/*/{test,tests,__tests__}/**",
      "!node_modules/*/{example,examples}/**",
      "!node_modules/*/*.md",
      "!node_modules/*/*.ts",
      "!node_modules/*/{.github,.vscode}/**"
    ],
    "npmRebuild": true,
    "buildDependenciesFromSource": false
  }
}
